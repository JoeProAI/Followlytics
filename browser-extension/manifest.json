{
  "manifest_version": 3,
  "name": "Followlytics - Twitter Follower Tracker",
  "version": "1.0.0",
  "description": "Track your Twitter followers and unfollowers with one click",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://followlytics.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Followlytics Follower Tracker"
  },
  "content_scripts": [
    {
      "matches": [
        "https://twitter.com/*/followers",
        "https://x.com/*/followers"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
