rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // User's followers collection
      match /followers/{followerId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // User's unfollow events
      match /unfollows/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      // User's subscription data
      match /subscription/{subscriptionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Scan jobs collection (server-side access)
    match /scan_jobs/{jobId} {
      allow read, write: if request.auth != null;
    }
    
    // Admin-only collections (for system operations)
    match /admin/{document=**} {
      allow read, write: if false; // Only server-side functions can access
    }
  }
}
